# Cloud Build ignore — based on .dockerignore but NOT excluding dist/
.git
.github
.paperclip
.pnpm-store
node_modules
**/node_modules
coverage
data
tmp
*.log
# Explicitly NOT ignoring dist/ — needed for pre-built deployment
# Workers not needed for server build
workers/
# UI source not needed (using pre-built or Vercel)
# Memory bank / docs not needed
memory-bank/
docs/
.agents/
.antigravity/
